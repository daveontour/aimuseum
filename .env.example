# Digital Museum — Go server environment variables
# Copy this file to .env and fill in your values.
# Variables marked REQUIRED must be set before the server will start.

# ── Database (REQUIRED) ────────────────────────────────────────────────────────
DB_HOST=localhost
#DB_HOST=host.docker.internal
#DB_HOST=db
DB_PORT=5432
DB_NAME=musegomulti
DB_USER=postgres
DB_PASSWORD=admin

# ── Authentication ──────────────────────────────────────────────────────────────
AUTH_REQUIRED=true

# ── Admin User, Only used once on startup when users table is created ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password


# ── Deployment Nature ───────────────────────────────────────────────────────
DEPLOYMENT_NATURE=web

# ── Server ─────────────────────────────────────────────────────────────────────
# Port for the Go server. Keep Python on 8000 and Go on 8001 during migration.
HOST_PORT=8080

# ── Application ────────────────────────────────────────────────────────────────
PAGE_TITLE=Digital Museum of SUBJECT_NAME
# Paths to Jinja2 templates and Python static assets (shared during migration).
# Defaults assume Go server runs from museum-of-dave-go/.
TEMPLATES_DIR=./templates
ASSET_STATIC_DIR=./static

# ── AI providers (at least one of Gemini or Anthropic should be set) ───────────
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL_NAME=gemini-2.5-flash

ANTHROPIC_API_KEY=sk-ant-api03-yChK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL_NAME=claude-sonnet-4-6

TAVILY_API_KEY=

KEYRING_PEPPER=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Attachments ────────────────────────────────────────────────────────────────
# Comma-separated allowed MIME types or extensions. Leave blank to allow all.
# NOTE: This value is also used as the crypto pepper in the sensitive-data
# encryption layer — do NOT change it after records have been created.
ATTACHMENT_ALLOWED_TYPES=
ATTACHMENT_MIN_SIZE=0

# ── Import defaults (shown as pre-filled values in the control panel UI) ───────
DEFAULT_PROCESS_ALL_FOLDERS=false
DEFAULT_NEW_ONLY_OPTION=true

DEFAULT_FILESYSTEM_IMPORT_CREATE_THUMBNAIL=false

DEFAULT_IMAGE_EXPORT_DIRECTORY=

DEFAULT_IMAP_HOST=
DEFAULT_IMAP_PORT=993
DEFAULT_IMAP_USERNAME=

YAHOO_APP_KEY=aaaaaaaaaaaaaaaaaaaaa

# ── Filesystem import exclusions ───────────────────────────────────────────────
# Comma-separated glob patterns for directories to skip during filesystem import.
FILESYSTEM_IMPORT_EXCLUDE_PATTERNS=

# ── Gmail OAuth2 ────────────────────────────────────────────────────────────────
# Create OAuth2 Web Application credentials in Google Cloud Console.
# Register the redirect URI below as an Authorised Redirect URI.
GMAIL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_REDIRECT_URL=http://localhost:8080/gmail/auth/callback

# ── Control the ZIP file archive upload size and processing chunks ────────────────────────────────────────────────────────────────
# The TUS protocol is used to upload the ZIP file archive in chunks.
# This uploads the file in chunks and then stitched it together on the server.
TUS_CHUNK_SIZE_MB=10     # chunk size in MB (default 10)
TUS_MAX_UPLOAD_GB=10

