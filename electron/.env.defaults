# Digital Museum — Configuration
# This file was created automatically on first run.
# Edit it to configure your instance, then restart the app.
# Location: %APPDATA%\digital-museum\.env

# ── SQLite (single-user; paths set automatically by the Electron app) ───────
# SQLITE_PATH and BILLING_SQLITE_PATH default to userData/data/main.sqlite and
# billing.sqlite when unset. Override to relocate the database files.
# SQLITE_PATH=C:/path/to/main.sqlite
# BILLING_SQLITE_PATH=C:/path/to/billing.sqlite

# ── Deployment ───────────────────────────────────────────────────────────────
DEPLOYMENT_NATURE=local
PAGE_TITLE=Digital Museum of SUBJECT_NAME

# ── Admin account (used on first startup to create the admin user) ───────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ── AI Provider Keys (at least one required) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# TAVILY_API_KEY=...

# ── Optional AI model overrides ──────────────────────────────────────────────
# CLAUDE_MODEL_NAME=claude-sonnet-4-6
# GEMINI_MODEL_NAME=gemini-2.5-flash
